{
    "name":"S-ATM",
    "description":"Tool that helps optimize workflow when using College Board's Student Question Bank",
    "version":"1.0",
    "manifest_version":3,
    "action":{
        "default_popup":"src/popup/popup.html"
    },
    "content_scripts":[{
        "matches":["https://mypractice.collegeboard.org/*"],
        "js":["src/content/content.js"],
        "run_at":"document_idle"
        }
    ],
    "permissions":["storage","scripting","activeTab","downloads"]

}